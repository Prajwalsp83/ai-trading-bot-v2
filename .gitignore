# =============================================================================
# Secrets — NEVER commit
# =============================================================================
.env
.env.*
*.token
.upstox_token.json

# =============================================================================
# Runtime state (regenerates from broker + journal)
# =============================================================================
.paper_state.json
.mt5_state.json
.mt5_smc_state.json
data/.control.json
data/.telegram_control_state.json

# =============================================================================
# Trade journals + caches (live data, not source)
# =============================================================================
data/mt5_trades.csv
data/mt5_smc_trades.csv
data/.av_news_cache.json
data/ml_dataset.parquet
data/ml_dataset.csv
data/trade_journal.csv
data/events.jsonl

# Keep the schema + sample calendar
!data/economic_calendar.json

# =============================================================================
# ML models (rebuild via scripts/train_meta_labeler.py)
# =============================================================================
models/*.pkl
models/*.json

# =============================================================================
# Logs (transient — NSSM rotates these)
# =============================================================================
logs/
data/*.log
*.log

# =============================================================================
# Python
# =============================================================================
.venv/
venv/
env/
__pycache__/
*.pyc
*.pyo
*.pyd
.pytest_cache/
.mypy_cache/
.ruff_cache/
*.egg-info/
dist/
build/

# =============================================================================
# OS / Editor cruft
# =============================================================================
.DS_Store
Thumbs.db
.vscode/
.idea/
*.swp
*.swo

# =============================================================================
# VPS-only binaries (don't commit Windows .exe)
# =============================================================================
nssm.exe
nssm.zip
